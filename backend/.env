# Server
PORT=8080
GIN_MODE=debug # change to 'release' in prod
API_BASE_URL="http://localhost:8080/v1" # Local override

# Database (From your Makefile context)
DATABASE_URL="postgres://resq:resq@localhost:5432/resq_dev?sslmode=disable"

# Redis
REDIS_URL="redis://localhost:6379/0"

# Auth
JWT_SECRET="super-secret-development-key-change-in-prod"
JWT_EXPIRATION_MINUTES=15

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
VALHALLA_URL="http://localhost:8002"

